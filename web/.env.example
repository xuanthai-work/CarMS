# CarMS — biến môi trường. Copy file này sang .env rồi điền giá trị thật.
#   cp .env.example .env

# --- Supabase Auth (BẮT BUỘC) ---
# Lấy tại: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Tuỳ chọn ---
# URL gốc của site, dùng cho link khôi phục mật khẩu gửi qua email.
# Dev có thể để trống (mặc định http://localhost:3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL cho Prisma (migrate/generate). Hiện app CHẠY trên data/db.json,
# Prisma mới scaffold nên chưa cần khi chỉ chạy dev.
DATABASE_URL=postgresql://user:password@localhost:5432/carms
