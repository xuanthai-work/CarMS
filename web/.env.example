# CarMS — biến môi trường. Copy file này sang .env rồi điền giá trị thật.
#   cp .env.example .env

# --- Supabase Auth (BẮT BUỘC) ---
# Lấy tại: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Tuỳ chọn ---
# URL gốc của site, dùng cho link khôi phục mật khẩu gửi qua email.
# Dev có thể để trống (mặc định http://localhost:3000).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database: Postgres của Supabase (BẮT BUỘC) ---
# Lấy tại: Supabase Dashboard → Project Settings → Database → Connection string.
#
# DATABASE_URL — app dùng lúc chạy. Dùng "Transaction pooler" (cổng 6543),
# hợp với serverless/Vercel.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# DIRECT_URL — dùng cho `prisma db push` / migrate (kết nối trực tiếp, cổng 5432).
# Tuỳ chọn: nếu bỏ trống sẽ fallback về DATABASE_URL.
DIRECT_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ============================================================================
# DEV LOCAL (Supabase CLI + Docker) — tách khỏi production
# ----------------------------------------------------------------------------
# Cài Docker Desktop, rồi: `npm run supabase:start` (lần đầu tải image, hơi lâu).
# Chạy `npm run supabase:status` để lấy API URL + anon key, điền như dưới đây
# vào .env (chỉ .env local — KHÔNG đụng biến trên Vercel). Prod trên Vercel vẫn
# trỏ project cloud như cũ → dev/prod tách hẳn nhau.
#
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<'anon key' in ra từ supabase status>
#   NEXT_PUBLIC_SITE_URL=http://localhost:3000
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# Sau khi điền xong, tạo schema + realtime + seed cho DB local: `npm run db:setup`
# Tạo user đăng nhập dev: mở Studio http://127.0.0.1:54323 → Authentication →
# Add user (email + password, tick "Auto Confirm User"). Hoặc đăng ký thẳng ở
# trang /login (local đã tắt xác nhận email).
# ============================================================================
