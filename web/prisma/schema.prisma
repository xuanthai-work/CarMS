generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id            String  @id
  plate         String  @unique
  seats         Int?
  status        String  @default("active")
  type          String  @default("own")
  inspectionDue String?
  insuranceDue  String?
  note          String?

  outboundTrips Trip[]  @relation("OutboundVehicle")
  returnTrips   Trip[]  @relation("ReturnVehicle")
  fuelEntries   FuelEntry[]
}

model Driver {
  id           String  @id
  name         String
  phone        String?
  licenseClass String?
  type         String  @default("own")
  note         String?

  outboundTrips Trip[]  @relation("OutboundDriver")
  returnTrips   Trip[]  @relation("ReturnDriver")
}

model Trip {
  id              String  @id
  customerName    String
  customerPhone   String?
  tourType        String  @default("1d")
  price           Float?
  deposit         Float?
  status          String  @default("pending")
  heldThroughTour Boolean @default(false)
  note            String?

  // ----- Lượt đi (Outbound) -----
  outboundDate      String
  outboundTime      String?
  outboundEndTime   String?
  outboundFrom      String
  outboundTo        String
  outboundVehicleId String?
  outboundDriverId  String?
  outboundSeatClass Int? // placeholder số chỗ khi chưa xếp xe cụ thể (VD 7, 16)

  outboundVehicle   Vehicle? @relation("OutboundVehicle", fields: [outboundVehicleId], references: [id])
  outboundDriver    Driver?  @relation("OutboundDriver", fields: [outboundDriverId], references: [id])

  // ----- Lượt về (Return) -----
  hasReturn         Boolean @default(false)
  returnDate        String?
  returnTime        String?
  returnEndTime     String?
  returnFrom        String?
  returnTo          String?
  returnVehicleId   String?
  returnDriverId    String?
  returnSeatClass   Int? // placeholder số chỗ khi chưa xếp xe cụ thể

  returnVehicle     Vehicle? @relation("ReturnVehicle", fields: [returnVehicleId], references: [id])
  returnDriver      Driver?  @relation("ReturnDriver", fields: [returnDriverId], references: [id])

  // ----- Chi phí (để tính lợi nhuận) -----
  fuelCost    Float? // xăng dầu
  tollCost    Float? // VETC / cầu đường
  partnerCost Float? // tiền thuê đối tác
  otherCost   Float? // chi phí khác
}

model FuelEntry {
  id            String   @id
  vehicleId     String
  refuelDate    String
  amount        Float
  paymentStatus String   @default("unpaid")
  paymentDate   String?
  payerName     String   @default("")
  note          String?  @default("")
  source        String   @default("manual")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([refuelDate])
  @@index([vehicleId, refuelDate])
  @@index([source])
}

model OfficeStaff {
  id              String  @id
  name            String
  phone           String?
  position        String? // chức vụ: điều hành, kế toán…
  baseSalary      Float?  // lương cơ bản (VND)
  startDate       String? // ngày vào làm (YYYY-MM-DD)
  note            String?
  dob             String? // ngày sinh (YYYY-MM-DD)
  gender          String? // Nam | Nữ | Khác
  email           String?
  idNumber        String? // CCCD
  socialInsurance String? // số bảo hiểm xã hội
  payday          Int?    // ngày nhận lương (trong tháng, 1–31)
}
